<Window x:Class="FocusGuard.StudyWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Focus Timer" Height="175" Width="290"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ResizeMode="NoResize" Loaded="Window_Loaded"
        ShowInTaskbar="False" Closing="Window_Closing"
        UseLayoutRounding="True" SnapsToDevicePixels="True" 
        TextOptions.TextFormattingMode="Display" TextOptions.TextRenderingMode="ClearType"
        MouseLeftButtonDown="Window_MouseLeftButtonDown" Cursor="SizeAll">
    <Grid Margin="15">
        <Border Name="WidgetBorder" CornerRadius="16" Background="#FFFFFF" MouseEnter="WidgetBorder_MouseEnter" MouseLeave="WidgetBorder_MouseLeave">
            <Border.Effect><DropShadowEffect Color="#0F172A" Opacity="0.15" BlurRadius="25" ShadowDepth="5" Direction="270"/></Border.Effect>
        </Border>
        
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MouseEnter="WidgetBorder_MouseEnter" MouseLeave="WidgetBorder_MouseLeave" Width="220">
            <TextBlock Name="TxtTimer" Text="05:00" FontSize="42" HorizontalAlignment="Center" Foreground="#0F172A" FontWeight="Black" FontFamily="Consolas, Arial"/>
            
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,2,0,0">
                <TextBlock Name="TxtStatus" Text="감시 중..." FontSize="14" Foreground="#10B981" FontWeight="Bold"/>
            </StackPanel>

            <ProgressBar Name="ProgressTimer" Height="6" Margin="0,15,0,0" BorderThickness="0" Background="#F1F5F9" Foreground="#3B82F6">
                <ProgressBar.Resources>
                    <Style TargetType="ProgressBar">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ProgressBar">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="3">
                                        <Border Name="PART_Indicator" Background="{TemplateBinding Foreground}" CornerRadius="3" HorizontalAlignment="Left"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ProgressBar.Resources>
            </ProgressBar>
            
            <Button Content="🚨 비상 해제" Margin="0,12,0,0" Height="26" Width="100" Background="#FEE2E2" Foreground="#EF4444" FontWeight="ExtraBold" FontSize="12" Cursor="Hand" Click="BtnEmergency_Click">
                <Button.Template><ControlTemplate TargetType="Button"><Border Background="{TemplateBinding Background}" CornerRadius="6"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border></ControlTemplate></Button.Template>
            </Button>
        </StackPanel>
    </Grid>
</Window>
