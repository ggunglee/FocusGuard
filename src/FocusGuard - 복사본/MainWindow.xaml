<Window x:Class="FocusGuard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Focus Guard" Height="750" Width="600"
        WindowStartupLocation="CenterScreen" WindowStyle="None" AllowsTransparency="True"
        UseLayoutRounding="True" SnapsToDevicePixels="True" 
        TextOptions.TextFormattingMode="Display" TextOptions.TextRenderingMode="ClearType"
        Loaded="Window_Loaded">
    
    <Border CornerRadius="20" BorderBrush="#E2E8F0" BorderThickness="1">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#F8FAFC" Offset="0.0"/>
                <GradientStop Color="#EFF6FF" Offset="1.0"/>
            </LinearGradientBrush>
        </Border.Background>
        <Grid>
            <Grid.RowDefinitions><RowDefinition Height="40"/><RowDefinition Height="*"/></Grid.RowDefinitions>
            <Border Grid.Row="0" Background="Transparent" MouseLeftButtonDown="TitleBar_MouseDown">
                <Button Content="✕" Width="40" HorizontalAlignment="Right" Background="Transparent" BorderThickness="0" FontSize="18" Foreground="#94A3B8" FontWeight="Bold" Click="CloseApp_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button"><TextBlock Text="{TemplateBinding Content}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{TemplateBinding Foreground}"/></ControlTemplate>
                    </Button.Template>
                </Button>
            </Border>

            <Grid Grid.Row="1" Margin="35,0,35,25">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock Text="🎯 Mission Board" FontSize="32" FontWeight="ExtraBold" Foreground="#0F172A" Margin="0,0,0,5" FontFamily="Malgun Gothic"/>
                    <Border Background="#FFFFFF" CornerRadius="12" Padding="15" Margin="0,15,0,20">
                        <Border.Effect><DropShadowEffect Color="#0F172A" Opacity="0.04" BlurRadius="15" ShadowDepth="3" Direction="270"/></Border.Effect>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="🍅 뽀모도로 루틴:" FontSize="15" FontWeight="Bold" Foreground="#EF4444" Margin="0,0,15,0" VerticalAlignment="Center"/>
                            <TextBlock Text="집중" FontSize="14" Foreground="#64748B" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBox Name="TxtFocusMin" Text="45" Width="35" TextAlignment="Center" FontWeight="Bold" FontSize="15" Foreground="#1E293B" BorderBrush="#E2E8F0" Padding="2"/>
                            <TextBlock Text="분 / 휴식" FontSize="14" Foreground="#64748B" VerticalAlignment="Center" Margin="15,0,8,0"/>
                            <TextBox Name="TxtRestMin" Text="10" Width="35" TextAlignment="Center" FontWeight="Bold" FontSize="15" Foreground="#1E293B" BorderBrush="#E2E8F0" Padding="2"/>
                            <TextBlock Text="분" FontSize="14" Foreground="#64748B" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <Border Grid.Row="1" Background="#F1F5F9" CornerRadius="14" Padding="20" Margin="0,0,0,20" BorderBrush="#E2E8F0" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="✨ 새로운 목표 설정하기" FontSize="15" FontWeight="Bold" Foreground="#334155" Margin="0,0,0,12"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBox Name="InputTitle" Width="180" Height="34" Padding="8,4" FontSize="14" Foreground="#0F172A" BorderBrush="#CBD5E1" Background="#FFFFFF" Tag="과제 이름"/>
                            <TextBlock Text="⏱️" Margin="12,0,8,0" VerticalAlignment="Center" FontSize="16"/>
                            <TextBox Name="InputTime" Width="45" Height="34" Padding="0,4" TextAlignment="Center" FontSize="14" FontWeight="Bold" Foreground="#3B82F6" BorderBrush="#CBD5E1" Background="#FFFFFF"/>
                            <TextBlock Text="분" Margin="8,0,20,0" VerticalAlignment="Center" Foreground="#64748B" FontSize="14"/>
                            <TextBlock Text="🖥️ 타겟 앱:" Margin="0,0,8,0" VerticalAlignment="Center" Foreground="#64748B" FontSize="14"/>
                            <TextBox Name="InputApp" Text="chrome" Width="75" Height="34" Padding="8,4" FontSize="14" Foreground="#10B981" FontWeight="Bold" BorderBrush="#CBD5E1" Background="#FFFFFF"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBox Name="InputRes" Width="370" Height="34" Padding="8,4" FontSize="13" Foreground="#475569" BorderBrush="#CBD5E1" Background="#FFFFFF"/>
                            <Button Content="📂" Width="34" Height="34" Margin="8,0,0,0" Background="#FFFFFF" BorderBrush="#CBD5E1" BorderThickness="1" Cursor="Hand" Click="BtnFindFile_Click">
                                <Button.Template><ControlTemplate TargetType="Button"><Border Background="{TemplateBinding Background}" CornerRadius="6" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border></ControlTemplate></Button.Template>
                            </Button>
                            <Button Content="추가" Width="65" Height="34" Margin="12,0,0,0" Background="#3B82F6" Foreground="White" FontWeight="Bold" FontSize="14" Cursor="Hand" Click="BtnAddMission_Click">
                                <Button.Template><ControlTemplate TargetType="Button"><Border Background="{TemplateBinding Background}" CornerRadius="8"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border></ControlTemplate></Button.Template>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="0,0,0,20">
                    <ItemsControl Name="ListMissions">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#FFFFFF" CornerRadius="14" Padding="18" Margin="4,4,4,12">
                                    <Border.Effect><DropShadowEffect Color="#0F172A" Opacity="0.06" BlurRadius="12" ShadowDepth="3" Direction="270"/></Border.Effect>
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                <TextBlock Text="{Binding title}" FontSize="16" FontWeight="ExtraBold" Foreground="#0F172A" Width="180" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding duration_minutes, StringFormat='⏱️ {0}분'}" Foreground="#3B82F6" FontSize="14" FontWeight="Bold" Margin="15,0,20,0"/>
                                                <TextBlock Text="{Binding target_app, StringFormat='🖥️ {0}'}" Foreground="#10B981" FontSize="14" FontWeight="Bold"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding resource_path}" FontSize="12" Foreground="#94A3B8" TextTrimming="CharacterEllipsis" MaxWidth="350"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Button Content="🗑" Width="36" Height="38" Margin="0,0,10,0" Background="#F8FAFC" Foreground="#EF4444" FontSize="16" Cursor="Hand" Click="BtnDeleteMission_Click">
                                                <Button.Template><ControlTemplate TargetType="Button"><Border Background="{TemplateBinding Background}" CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border></ControlTemplate></Button.Template>
                                            </Button>
                                            <Button Content="▶ START" Width="90" Height="38" Background="#1E293B" Foreground="White" FontWeight="ExtraBold" FontSize="13" Cursor="Hand" Click="BtnStartMission_Click">
                                                <Button.Template><ControlTemplate TargetType="Button"><Border Background="{TemplateBinding Background}" CornerRadius="8"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border></ControlTemplate></Button.Template>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="📊 집중 대시보드" Width="170" Height="48" Background="#3B82F6" Foreground="White" FontWeight="Bold" FontSize="15" Margin="0,0,15,0" Cursor="Hand" Click="Dashboard_Click">
                        <Button.Template><ControlTemplate TargetType="Button"><Border Background="{TemplateBinding Background}" CornerRadius="12"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border></ControlTemplate></Button.Template>
                    </Button>
                    <Button Content="⚙️ 환경 설정" Width="120" Height="48" Background="#E2E8F0" Foreground="#334155" FontWeight="Bold" FontSize="15" Cursor="Hand" Click="Settings_Click">
                        <Button.Template><ControlTemplate TargetType="Button"><Border Background="{TemplateBinding Background}" CornerRadius="12"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border></ControlTemplate></Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
