<Window x:Class="FocusGuard.RestOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RestTime" WindowState="Maximized" WindowStyle="None" Topmost="True" Background="#0F172A"
        UseLayoutRounding="True" SnapsToDevicePixels="True" TextOptions.TextFormattingMode="Display" TextOptions.TextRenderingMode="ClearType">
    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="☕ 찐 휴 식 시 간 입 니 다" FontSize="36" FontWeight="Black" Foreground="#FFFFFF" HorizontalAlignment="Center" Margin="0,0,0,15"/>
            <TextBlock Text="지금은 모니터에서 눈을 떼고 잠시 스트레칭을 하세요." FontSize="18" Foreground="#94A3B8" HorizontalAlignment="Center" Margin="0,0,0,40"/>
            <Border BorderBrush="#EF4444" BorderThickness="2" CornerRadius="20" Padding="25,10" Background="#27272A" HorizontalAlignment="Center">
                <TextBlock Text="🔒 시스템 잠금 중 (휴식 종료 시 자동 잠금 해제)" FontSize="14" FontWeight="Bold" Foreground="#F87171"/>
            </Border>
        </StackPanel>
    </Grid>
</Window>
