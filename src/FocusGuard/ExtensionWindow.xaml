<Window x:Class="FocusGuard.ExtensionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="시간 연장" Height="250" Width="400"
        WindowStartupLocation="CenterScreen" WindowStyle="None" Background="#EEF2F6" Topmost="True">
    <Border BorderBrush="#3B82F6" BorderThickness="3" CornerRadius="12" Background="#FFFFFF">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="⏱️ 목표 시간 종료!" FontSize="24" FontWeight="Bold" Foreground="#1E293B" HorizontalAlignment="Center" Margin="0,0,0,10"/>
            <TextBlock Text="아직 과제가 끝나지 않았나요? 시간을 연장할 수 있습니다." FontSize="14" Foreground="#64748B" HorizontalAlignment="Center" Margin="0,0,0,20"/>
            
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,25">
                <TextBox Name="TxtExtraMinutes" Text="30" Width="60" Height="36" FontSize="20" FontWeight="Bold" TextAlignment="Center" Foreground="#3B82F6" BorderBrush="#CBD5E1" BorderThickness="1"/>
                <TextBlock Text="분 연장하기" FontSize="16" FontWeight="Bold" Foreground="#334155" VerticalAlignment="Center" Margin="10,0,0,0"/>
            </StackPanel>
            
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="연장하고 계속" Width="140" Height="40" Background="#3B82F6" Foreground="White" FontWeight="Bold" Margin="0,0,10,0" Click="BtnExtend_Click">
                    <Button.Template><ControlTemplate TargetType="Button"><Border Background="{TemplateBinding Background}" CornerRadius="8"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border></ControlTemplate></Button.Template>
                </Button>
                <Button Content="완료하고 끝내기" Width="140" Height="40" Background="#10B981" Foreground="White" FontWeight="Bold" Click="BtnFinish_Click">
                    <Button.Template><ControlTemplate TargetType="Button"><Border Background="{TemplateBinding Background}" CornerRadius="8"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border></ControlTemplate></Button.Template>
                </Button>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
