<Window x:Class="FocusGuard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Focus Guard" Height="640" Width="430" MinWidth="340" MinHeight="550"
        WindowStartupLocation="CenterScreen" WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="CanResize"
        UseLayoutRounding="True" SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display" TextOptions.TextRenderingMode="ClearType"
        Loaded="Window_Loaded">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="40" 
                      ResizeBorderThickness="8" 
                      GlassFrameThickness="0" 
                      CornerRadius="20"/>
    </WindowChrome.WindowChrome>

    <Border CornerRadius="20" BorderBrush="#E2E8F0" BorderThickness="1">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#F8FAFC" Offset="0.0"/>
                <GradientStop Color="#EFF6FF" Offset="1.0"/>
            </LinearGradientBrush>
        </Border.Background>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="35"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 커스텀 타이틀바 영역 (드래그 가능 및 닫기 버튼) -->
            <Border Grid.Row="0" Background="Transparent" MouseLeftButtonDown="TitleBar_MouseDown">
                <Button Content="✕" Width="40" HorizontalAlignment="Right" Background="Transparent" BorderThickness="0" FontSize="16" Foreground="#94A3B8" FontWeight="Bold" Click="CloseApp_Click"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <TextBlock Text="{TemplateBinding Content}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{TemplateBinding Foreground}"/>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Border>

            <!-- 콘텐츠 영역 -->
            <Grid Grid.Row="1" Margin="20,0,20,15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock Text="🎯 Mission Board" FontSize="26" FontWeight="ExtraBold" Foreground="#0F172A" Margin="0,0,0,2" FontFamily="Malgun Gothic"/>

                    <Border Background="#FFFFFF" CornerRadius="10" Padding="10,8" Margin="0,6,0,10">
                        <Border.Effect>
                            <DropShadowEffect Color="#0F172A" Opacity="0.04" BlurRadius="10" ShadowDepth="2" Direction="270"/>
                        </Border.Effect>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="🍅 뽀모도로 루틴:" FontSize="13" FontWeight="Bold" Foreground="#EF4444" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="집중" FontSize="12" Foreground="#64748B" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBox Name="TxtFocusMin" Text="45" Width="30" TextAlignment="Center" FontWeight="Bold" FontSize="13" Foreground="#1E293B" BorderBrush="#E2E8F0" Padding="2" VerticalContentAlignment="Center"/>
                            <TextBlock Text="분 / 휴식" FontSize="12" Foreground="#64748B" VerticalAlignment="Center" Margin="10,0,6,0"/>
                            <TextBox Name="TxtRestMin" Text="10" Width="30" TextAlignment="Center" FontWeight="Bold" FontSize="13" Foreground="#1E293B" BorderBrush="#E2E8F0" Padding="2" VerticalContentAlignment="Center"/>
                            <TextBlock Text="분" FontSize="12" Foreground="#64748B" VerticalAlignment="Center" Margin="6,0,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- 새로운 목표 설정 영역 -->
                <Border Grid.Row="1" Background="#F1F5F9" CornerRadius="12" Padding="12" Margin="0,0,0,10" BorderBrush="#E2E8F0" BorderThickness="1">
                    <StackPanel>
                        <!-- 헤더 정보 라인 (새로운 목표 설정, 기록 사이트 체크박스, 선택된 앱 라벨) -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="✨ 새로운 목표 설정하기" FontSize="13" FontWeight="Bold" Foreground="#334155" VerticalAlignment="Center"/>
                            <CheckBox Grid.Column="1" Name="ChkUseReadingLog" Content="📚 기록 사이트" Margin="10,0,0,0" VerticalAlignment="Center" FontSize="11" FontWeight="SemiBold" Foreground="#475569" Cursor="Hand"
                                      ToolTip="환경 설정에 저장한 기록용 사이트를 작은 창으로 함께 엽니다."/>
                            <TextBlock Grid.Column="2" Name="TxtSelectedApps" Text="선택 앱 없음" HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="#10B981" FontSize="11" FontWeight="Bold"
                                       ToolTip="감시가 적용된 허용 앱 이름들"/>
                        </Grid>

                        <!-- 입력 1라인 (과제 이름, 시간 입력, 앱 선택 버튼) -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <TextBox Name="InputTitle" Grid.Column="0" Height="30" Padding="6,2" FontSize="12" Foreground="#0F172A" BorderBrush="#CBD5E1" Background="#FFFFFF" 
                                     VerticalContentAlignment="Center" ToolTip="집중할 과제명을 적어주세요."/>
                            
                            <TextBlock Grid.Column="1" Text="⏱️" Margin="8,0,4,0" VerticalAlignment="Center" FontSize="13"/>
                            <TextBox Name="InputTime" Grid.Column="2" Width="35" Height="30" Padding="0,2" TextAlignment="Center" FontSize="12" FontWeight="Bold" Foreground="#3B82F6" BorderBrush="#CBD5E1" Background="#FFFFFF" VerticalContentAlignment="Center"/>
                            <TextBlock Grid.Column="3" Text="분" Margin="4,0,8,0" VerticalAlignment="Center" Foreground="#64748B" FontSize="12"/>
                            
                            <Button Grid.Column="4" Content="앱" Width="34" Height="30" Background="#FFFFFF" Foreground="#334155" FontWeight="Bold" FontSize="11" BorderBrush="#CBD5E1" BorderThickness="1" Cursor="Hand" Click="BtnPickApp_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="5" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            
                            <TextBox Name="InputApp" Visibility="Collapsed"/>
                        </Grid>

                        <!-- 시간 간편 선택 라인 -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,-4,0,8">
                            <Button Content="비우기" Width="45" Height="22" Background="#F1F5F9" Foreground="#94A3B8" FontSize="11" FontWeight="Bold" BorderThickness="0" Margin="0,0,4,0" Click="BtnPresetTimeClear_Click" Cursor="Hand">
                                <Button.Template><ControlTemplate TargetType="Button"><Border Background="{TemplateBinding Background}" CornerRadius="11"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border></ControlTemplate></Button.Template>
                            </Button>
                            <Button Content="+5분" Width="40" Height="22" Background="#E2E8F0" Foreground="#475569" FontSize="11" FontWeight="Bold" BorderThickness="0" Margin="0,0,4,0" Click="BtnPresetTime_Click" Tag="5" Cursor="Hand">
                                <Button.Template><ControlTemplate TargetType="Button"><Border Background="{TemplateBinding Background}" CornerRadius="11"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border></ControlTemplate></Button.Template>
                            </Button>
                            <Button Content="+10분" Width="45" Height="22" Background="#E2E8F0" Foreground="#475569" FontSize="11" FontWeight="Bold" BorderThickness="0" Margin="0,0,4,0" Click="BtnPresetTime_Click" Tag="10" Cursor="Hand">
                                <Button.Template><ControlTemplate TargetType="Button"><Border Background="{TemplateBinding Background}" CornerRadius="11"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border></ControlTemplate></Button.Template>
                            </Button>
                            <Button Content="+30분" Width="45" Height="22" Background="#E2E8F0" Foreground="#475569" FontSize="11" FontWeight="Bold" BorderThickness="0" Margin="0,0,4,0" Click="BtnPresetTime_Click" Tag="30" Cursor="Hand">
                                <Button.Template><ControlTemplate TargetType="Button"><Border Background="{TemplateBinding Background}" CornerRadius="11"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border></ControlTemplate></Button.Template>
                            </Button>
                            <Button Content="+1시간" Width="45" Height="22" Background="#E2E8F0" Foreground="#475569" FontSize="11" FontWeight="Bold" BorderThickness="0" Margin="0,0,4,0" Click="BtnPresetTime_Click" Tag="60" Cursor="Hand">
                                <Button.Template><ControlTemplate TargetType="Button"><Border Background="{TemplateBinding Background}" CornerRadius="11"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border></ControlTemplate></Button.Template>
                            </Button>
                        </StackPanel>

                        <!-- 입력 2라인 (리소스 URL/경로 입력, 붙여넣기, 파일찾기, 추가 버튼) -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBox Name="InputRes" Grid.Column="0" Height="30" Padding="6,2" FontSize="12" Foreground="#475569" BorderBrush="#CBD5E1" Background="#FFFFFF"
                                     VerticalContentAlignment="Center" ToolTip="URL이나 파일 경로를 입력하세요. 여러 개는 콤마로 구분할 수 있습니다."/>

                            <Button Grid.Column="1" Content="📋" Width="30" Height="30" Margin="6,0,0,0" Background="#FFFFFF" Foreground="#334155" BorderBrush="#CBD5E1" BorderThickness="1" FontSize="12" FontWeight="Bold" Cursor="Hand" Click="BtnPasteUrl_Click" ToolTip="클립보드에서 붙여넣기">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="5" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <Button Grid.Column="2" Content="📂" Width="30" Height="30" Margin="6,0,0,0" Background="#FFFFFF" BorderBrush="#CBD5E1" BorderThickness="1" Cursor="Hand" Click="BtnFindFile_Click" ToolTip="파일 선택">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="5" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <Button Grid.Column="3" Content="추가" Width="50" Height="30" Margin="8,0,0,0" Background="#3B82F6" Foreground="White" FontWeight="Bold" FontSize="12" Cursor="Hand" Click="BtnAddMission_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 미션 리스트 영역 -->
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="0,0,0,10">
                    <ItemsControl Name="ListMissions">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#FFFFFF" CornerRadius="10" Padding="12,10" Margin="2,2,2,8">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#0F172A" Opacity="0.04" BlurRadius="8" ShadowDepth="2" Direction="270"/>
                                    </Border.Effect>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- 1. 좌측: 과제 정보 (과제명 & 링크 시작 위치 완벽 수직 일치!) -->
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding title}" FontSize="14" FontWeight="ExtraBold" Foreground="#0F172A" TextTrimming="CharacterEllipsis" MaxWidth="150" Margin="0,0,0,4"/>
                                            <TextBlock Text="{Binding DisplayResourcePath}" ToolTip="{Binding resource_path}" FontSize="11" Foreground="#94A3B8" TextTrimming="CharacterEllipsis" MaxWidth="150"/>
                                        </StackPanel>

                                        <!-- 2. 중간: 메타 정보 (시간 & 앱) -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,12,0" HorizontalAlignment="Right">
                                            <TextBlock Text="{Binding duration_minutes, StringFormat='⏱️ {0}분'}" Foreground="#3B82F6" FontSize="11" FontWeight="Bold" Margin="0,0,0,4"/>
                                            <TextBlock Text="{Binding target_app, StringFormat='🖥️ {0}'}" Foreground="#10B981" FontSize="11" FontWeight="Bold"/>
                                        </StackPanel>

                                        <!-- 3. 우측: 조작 버튼 (삭제 & START) -->
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Button Content="🗑" Width="30" Height="32" Margin="0,0,6,0" Background="#F8FAFC" Foreground="#EF4444" FontSize="14" Cursor="Hand" Click="BtnDeleteMission_Click">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" CornerRadius="6" BorderBrush="#E2E8F0" BorderThickness="1">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>

                                            <Button Content="▶ START" Width="70" Height="32" Background="#1E293B" Foreground="White" FontWeight="ExtraBold" FontSize="11" Cursor="Hand" Click="BtnStartMission_Click">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- 하단 버튼 영역 -->
                <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="📊 집중 대시보드" Width="130" Height="38" Background="#3B82F6" Foreground="White" FontWeight="Bold" FontSize="12" Margin="0,0,8,0" Cursor="Hand" Click="Dashboard_Click">
                         <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Content="📝 메모 기록" Width="110" Height="38" Background="#FEF08A" Foreground="#854D0E" FontWeight="Bold" FontSize="12" Margin="0,0,8,0" Cursor="Hand" Click="MemoHistory_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Content="⚙️ 환경 설정" Width="100" Height="38" Background="#E2E8F0" Foreground="#334155" FontWeight="Bold" FontSize="12" Cursor="Hand" Click="Settings_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
