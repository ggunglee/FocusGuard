<Window x:Class="FocusGuard.EmergencyUnlockWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="비상 해제" WindowStartupLocation="CenterScreen" Width="700" Height="500" 
        WindowStyle="None" Topmost="True" Background="#EEF2F6"
        UseLayoutRounding="True" SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display" TextOptions.TextRenderingMode="ClearType">
    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="600">
            <TextBlock Text="🚨 비상 해제 (명문장 입력)" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" Foreground="#1E293B" Margin="0,0,0,20"/>
            <TextBlock Text="아래 문장을 띄어쓰기와 마침표까지 정확하게 입력해야 잠금이 해제됩니다." FontSize="14" Foreground="#64748B" HorizontalAlignment="Center" Margin="0,0,0,30"/>
            
            <Border Background="White" Padding="25" CornerRadius="12" Margin="0,0,0,20">
                <Border.Effect><DropShadowEffect Color="Black" Opacity="0.05" BlurRadius="10" ShadowDepth="2"/></Border.Effect>
                <TextBlock Name="TxtQuote" Text="명문장이 여기에 표시됩니다." FontSize="18" FontWeight="SemiBold" Foreground="#334155" TextWrapping="Wrap" TextAlignment="Center"/>
            </Border>
            
            <TextBox Name="InputQuote" FontSize="18" Height="100" TextWrapping="Wrap" Padding="15" Margin="0,0,0,30" BorderBrush="#CBD5E1" BorderThickness="2" KeyDown="InputQuote_KeyDown">
                <TextBox.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style></TextBox.Resources>
            </TextBox>
            
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="입력 완료 (해제)" Width="150" Height="45" Background="#3B82F6" Foreground="White" FontWeight="Bold" Margin="0,0,15,0" Click="BtnConfirm_Click">
                    <Button.Template><ControlTemplate TargetType="Button"><Border Background="{TemplateBinding Background}" CornerRadius="8"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border></ControlTemplate></Button.Template>
                </Button>
                <Button Content="포기하고 복귀" Width="150" Height="45" Background="#94A3B8" Foreground="White" FontWeight="Bold" Click="BtnCancel_Click">
                    <Button.Template><ControlTemplate TargetType="Button"><Border Background="{TemplateBinding Background}" CornerRadius="8"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border></ControlTemplate></Button.Template>
                </Button>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
