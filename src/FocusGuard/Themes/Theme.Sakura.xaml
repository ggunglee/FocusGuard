<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Sakura Theme -->
    <!-- Window Background Colors -->
    <Color x:Key="WindowBackgroundStartColor">#FFF5F5</Color>
    <Color x:Key="WindowBackgroundEndColor">#FFE3E3</Color>
    
    <LinearGradientBrush x:Key="WindowBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource WindowBackgroundStartColor}" Offset="0.0"/>
        <GradientStop Color="{StaticResource WindowBackgroundEndColor}" Offset="1.0"/>
    </LinearGradientBrush>

    <!-- General Border -->
    <SolidColorBrush x:Key="WindowBorderBrush" Color="#FCD5CE"/>
    
    <!-- Text Colors -->
    <SolidColorBrush x:Key="TextTitleBrush" Color="#4A2E35"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#4A2E35"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#8C6A73"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="#C7A3AB"/>
    
    <!-- Card / Panel Colors -->
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="CardBorderBrush" Color="#FCD5CE"/>
    <Color x:Key="CardShadowColor">#8C6A73</Color>
    
    <!-- Inputs (TextBox, etc) -->
    <SolidColorBrush x:Key="InputBackgroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="InputForegroundBrush" Color="#4A2E35"/>
    <SolidColorBrush x:Key="InputBorderBrush" Color="#FFB3C1"/>

    <!-- Buttons -->
    <!-- Primary (Accent) -->
    <SolidColorBrush x:Key="PrimaryButtonBrush" Color="#FF8FAB"/>
    <SolidColorBrush x:Key="PrimaryButtonTextBrush" Color="#FFFFFF"/>
    <!-- Secondary (Grey) -->
    <SolidColorBrush x:Key="SecondaryButtonBrush" Color="#FFE5EC"/>
    <SolidColorBrush x:Key="SecondaryButtonTextBrush" Color="#FF5C8A"/>
    <!-- Presets -->
    <SolidColorBrush x:Key="PresetButtonBrush" Color="#FFF0F3"/>
    <SolidColorBrush x:Key="PresetButtonTextBrush" Color="#FF758F"/>
    <!-- Danger -->
    <SolidColorBrush x:Key="DangerButtonBrush" Color="#FF4D6D"/>
    <SolidColorBrush x:Key="DangerButtonTextBrush" Color="#FFFFFF"/>
    <!-- Success / Start -->
    <SolidColorBrush x:Key="SuccessButtonBrush" Color="#4A2E35"/>
    <SolidColorBrush x:Key="SuccessButtonTextBrush" Color="#FFFFFF"/>
    <!-- Memo -->
    <SolidColorBrush x:Key="MemoButtonBrush" Color="#FFE5EC"/>
    <SolidColorBrush x:Key="MemoButtonTextBrush" Color="#FF5C8A"/>
    
    <!-- Accent Color (e.g. timers, special labels) -->
    <SolidColorBrush x:Key="AccentBrush" Color="#FF8FAB"/>
    <SolidColorBrush x:Key="SuccessLabelBrush" Color="#FF758F"/>
    <SolidColorBrush x:Key="DangerLabelBrush" Color="#FF4D6D"/>
    <SolidColorBrush x:Key="TimerProgressTrackBrush" Color="#FFF0F3"/>
</ResourceDictionary>
