<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Dark Theme -->
    <!-- Window Background Colors -->
    <Color x:Key="WindowBackgroundStartColor">#1E293B</Color>
    <Color x:Key="WindowBackgroundEndColor">#0F172A</Color>
    
    <LinearGradientBrush x:Key="WindowBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource WindowBackgroundStartColor}" Offset="0.0"/>
        <GradientStop Color="{StaticResource WindowBackgroundEndColor}" Offset="1.0"/>
    </LinearGradientBrush>

    <!-- General Border -->
    <SolidColorBrush x:Key="WindowBorderBrush" Color="#334155"/>
    
    <!-- Text Colors -->
    <SolidColorBrush x:Key="TextTitleBrush" Color="#F8FAFC"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#F1F5F9"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#CBD5E1"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="#64748B"/>
    
    <!-- Card / Panel Colors -->
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#1E293B"/>
    <SolidColorBrush x:Key="CardBorderBrush" Color="#334155"/>
    <Color x:Key="CardShadowColor">#000000</Color>
    
    <!-- Inputs (TextBox, etc) -->
    <SolidColorBrush x:Key="InputBackgroundBrush" Color="#0F172A"/>
    <SolidColorBrush x:Key="InputForegroundBrush" Color="#F8FAFC"/>
    <SolidColorBrush x:Key="InputBorderBrush" Color="#475569"/>

    <!-- Buttons -->
    <!-- Primary (Accent) -->
    <SolidColorBrush x:Key="PrimaryButtonBrush" Color="#6366F1"/>
    <SolidColorBrush x:Key="PrimaryButtonTextBrush" Color="#FFFFFF"/>
    <!-- Secondary (Grey) -->
    <SolidColorBrush x:Key="SecondaryButtonBrush" Color="#334155"/>
    <SolidColorBrush x:Key="SecondaryButtonTextBrush" Color="#E2E8F0"/>
    <!-- Presets -->
    <SolidColorBrush x:Key="PresetButtonBrush" Color="#334155"/>
    <SolidColorBrush x:Key="PresetButtonTextBrush" Color="#CBD5E1"/>
    <!-- Danger -->
    <SolidColorBrush x:Key="DangerButtonBrush" Color="#EF4444"/>
    <SolidColorBrush x:Key="DangerButtonTextBrush" Color="#FFFFFF"/>
    <!-- Success / Start -->
    <SolidColorBrush x:Key="SuccessButtonBrush" Color="#F1F5F9"/>
    <SolidColorBrush x:Key="SuccessButtonTextBrush" Color="#0F172A"/>
    <!-- Memo -->
    <SolidColorBrush x:Key="MemoButtonBrush" Color="#EAB308"/>
    <SolidColorBrush x:Key="MemoButtonTextBrush" Color="#451A03"/>
    
    <!-- Accent Color (e.g. timers, special labels) -->
    <SolidColorBrush x:Key="AccentBrush" Color="#818CF8"/>
    <SolidColorBrush x:Key="SuccessLabelBrush" Color="#34D399"/>
    <SolidColorBrush x:Key="DangerLabelBrush" Color="#F87171"/>
    <SolidColorBrush x:Key="TimerProgressTrackBrush" Color="#0F172A"/>
</ResourceDictionary>
