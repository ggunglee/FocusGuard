<Window x:Class="FocusGuard.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="집중 리포트" Height="750" Width="900"
        WindowStartupLocation="CenterOwner" Background="#F8FAFC" WindowStyle="ToolWindow"
        UseLayoutRounding="True" SnapsToDevicePixels="True" TextOptions.TextFormattingMode="Display" TextOptions.TextRenderingMode="ClearType">
    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <TextBlock Text="📊 나의 집중 리포트" FontSize="26" FontWeight="ExtraBold" Foreground="#1E293B"/>
            <Border Background="#FEF08A" CornerRadius="8" Padding="10,5" Margin="20,0,0,0" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🔥 연속 집중 달성: " FontSize="14" FontWeight="Bold" Foreground="#854D0E"/>
                    <TextBlock Name="TxtStreak" Text="0일째!" FontSize="16" FontWeight="Black" Foreground="#EA580C"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,0,0,15">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="20"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <Border Grid.Column="0" Background="White" CornerRadius="16" Padding="20">
                <Border.Effect><DropShadowEffect Color="Black" Opacity="0.04" BlurRadius="12" ShadowDepth="2"/></Border.Effect>
                <StackPanel>
                    <TextBlock Text="[ 오늘 ]" FontSize="18" FontWeight="ExtraBold" Foreground="#3B82F6" Margin="0,0,0,15" HorizontalAlignment="Center"/>
                    <TextBlock Text="⏱️ 총 집중 시간" FontSize="13" FontWeight="Bold" Foreground="#64748B"/><TextBlock Name="TxtTodayFocus" Text="0분" FontSize="26" FontWeight="Black" Foreground="#1E293B" Margin="0,5,0,15"/>
                    <TextBlock Text="⚠️ 총 딴짓 시간" FontSize="13" FontWeight="Bold" Foreground="#64748B"/><TextBlock Name="TxtTodayDistract" Text="0초" FontSize="26" FontWeight="Black" Foreground="#EF4444" Margin="0,5,0,15"/>
                    <TextBlock Text="🎯 완료한 세션" FontSize="13" FontWeight="Bold" Foreground="#64748B"/><TextBlock Name="TxtTodaySessions" Text="0개" FontSize="26" FontWeight="Black" Foreground="#10B981" Margin="0,5,0,15"/>
                    <TextBlock Text="✨ 몰입도 점수" FontSize="13" FontWeight="Bold" Foreground="#64748B"/><TextBlock Name="TxtTodayRatio" Text="0%" FontSize="26" FontWeight="Black" Foreground="#8B5CF6" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Background="White" CornerRadius="16" Padding="20">
                <Border.Effect><DropShadowEffect Color="Black" Opacity="0.04" BlurRadius="12" ShadowDepth="2"/></Border.Effect>
                <StackPanel>
                    <TextBlock Text="[ 최근 7일 ]" FontSize="18" FontWeight="ExtraBold" Foreground="#10B981" Margin="0,0,0,15" HorizontalAlignment="Center"/>
                    <TextBlock Text="⏱️ 누적 집중 시간" FontSize="13" FontWeight="Bold" Foreground="#64748B"/><TextBlock Name="TxtWeekFocus" Text="0시간 0분" FontSize="26" FontWeight="Black" Foreground="#1E293B" Margin="0,5,0,15"/>
                    <TextBlock Text="⚠️ 누적 딴짓 시간" FontSize="13" FontWeight="Bold" Foreground="#64748B"/><TextBlock Name="TxtWeekDistract" Text="0분 0초" FontSize="26" FontWeight="Black" Foreground="#EF4444" Margin="0,5,0,15"/>
                    <TextBlock Text="📚 누적 완료 세션" FontSize="13" FontWeight="Bold" Foreground="#64748B"/><TextBlock Name="TxtWeekSessions" Text="0개" FontSize="26" FontWeight="Black" Foreground="#3B82F6" Margin="0,5,0,15"/>
                    <TextBlock Text="📈 주간 평균 몰입도" FontSize="13" FontWeight="Bold" Foreground="#64748B"/><TextBlock Name="TxtWeekRatio" Text="0%" FontSize="26" FontWeight="Black" Foreground="#8B5CF6" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- 오늘 완료한 과제 목록 리스트뷰 추가 -->
        <Border Grid.Row="2" Background="White" CornerRadius="16" Padding="20">
            <Border.Effect><DropShadowEffect Color="Black" Opacity="0.04" BlurRadius="12" ShadowDepth="2"/></Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="📋 오늘 완료한 과제 이력" FontSize="18" FontWeight="ExtraBold" Foreground="#0F172A" Margin="0,0,0,10"/>
                <ListView Grid.Row="1" Name="ListTodayMissions" BorderThickness="0" Background="Transparent" ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="과제명" DisplayMemberBinding="{Binding target_name}" Width="280"/>
                            <GridViewColumn Header="공부 시간" DisplayMemberBinding="{Binding DisplayFocusTime}" Width="150"/>
                            <GridViewColumn Header="딴짓 시간" DisplayMemberBinding="{Binding DisplayDistractTime}" Width="120"/>
                            <GridViewColumn Header="시작 시각" DisplayMemberBinding="{Binding DisplayStartedAt}" Width="150"/>
                            <GridViewColumn Header="삭제" Width="70">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="🗑" Width="32" Height="24" Background="#FEE2E2" Foreground="#EF4444" FontWeight="Bold" FontSize="11" Cursor="Hand" Click="BtnDeleteSession_Click" ToolTip="공부 기록 삭제">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="4" BorderBrush="#FCA5A5" BorderThickness="1">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Grid>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
            <Button Content="📊 CSV 데이터 내보내기" Height="42" Width="180" Background="#10B981" Foreground="White" FontWeight="Bold" FontSize="14" Click="BtnExport_Click" Margin="0,0,15,0" Cursor="Hand">
                <Button.Template><ControlTemplate TargetType="Button"><Border Background="{TemplateBinding Background}" CornerRadius="10"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border></ControlTemplate></Button.Template>
            </Button>
            <Button Content="닫기" Height="42" Width="100" Background="#1E293B" Foreground="White" FontWeight="Bold" FontSize="14" Click="Close_Click" Cursor="Hand">
                <Button.Template><ControlTemplate TargetType="Button"><Border Background="{TemplateBinding Background}" CornerRadius="10"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border></ControlTemplate></Button.Template>
            </Button>
        </StackPanel>
    </Grid>
</Window>
