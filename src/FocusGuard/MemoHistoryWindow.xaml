<Window x:Class="FocusGuard.MemoHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="공부 메모 기록" Height="540" Width="760"
        WindowStartupLocation="CenterOwner" Background="#F8FAFC" WindowStyle="ToolWindow"
        UseLayoutRounding="True" SnapsToDevicePixels="True" TextOptions.TextFormattingMode="Display" TextOptions.TextRenderingMode="ClearType"
        Loaded="Window_Loaded">
    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 상단 헤더 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
            <TextBlock Text="📝 공부 메모 기록" FontSize="24" FontWeight="ExtraBold" Foreground="#1E293B" VerticalAlignment="Center"/>
            <CheckBox Name="ChkOnlyWithMemo" Content="메모가 있는 세션만 보기" Margin="20,0,0,0" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold" Foreground="#475569" IsChecked="True" Checked="ChkOnlyWithMemo_Changed" Unchecked="ChkOnlyWithMemo_Changed" Cursor="Hand"/>
        </StackPanel>

        <!-- 메인 콘텐츠 영역 (2분할 Grid) -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 좌측: 세션 목록 -->
            <Border Grid.Column="0" Background="White" CornerRadius="16" BorderBrush="#E2E8F0" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect Color="Black" Opacity="0.03" BlurRadius="10" ShadowDepth="1"/>
                </Border.Effect>
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Text="세션 목록" FontSize="13" FontWeight="Bold" Foreground="#64748B" Margin="4,0,0,8"/>
                    
                    <ListBox Grid.Row="1" Name="ListSessions" BorderThickness="0" Background="Transparent" 
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollBarVisibility="Auto"
                             SelectionChanged="ListSessions_SelectionChanged">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Margin" Value="0,0,0,6"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border Name="Border" CornerRadius="8" Padding="10,8" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1">
                                                <ContentPresenter />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Border" Property="Background" Value="#EFF6FF"/>
                                                    <Setter TargetName="Border" Property="BorderBrush" Value="#3B82F6"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Border" Property="Background" Value="#F1F5F9"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock Text="{Binding DisplayTitle}" FontSize="13" FontWeight="Bold" Foreground="#1E293B" TextTrimming="CharacterEllipsis"/>
                                    <Grid Margin="0,4,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding DisplayTime}" FontSize="11" Foreground="#94A3B8"/>
                                        <TextBlock Grid.Column="1" Text="📝 있음" FontSize="10" FontWeight="Bold" Foreground="#3B82F6" Visibility="{Binding MemoVisibility}"/>
                                    </Grid>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- 우측: 선택된 세션 상세 및 메모 -->
            <Border Grid.Column="2" Background="White" CornerRadius="16" BorderBrush="#E2E8F0" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect Color="Black" Opacity="0.03" BlurRadius="10" ShadowDepth="1"/>
                </Border.Effect>
                <Grid Margin="18">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 세션 메타 정보 -->
                    <StackPanel Grid.Row="0" Name="PanelMeta" Visibility="Collapsed" Margin="0,0,0,12">
                        <TextBlock Name="TxtDetailTitle" Text="과제명" FontSize="16" FontWeight="ExtraBold" Foreground="#1E293B"/>
                        <TextBlock Name="TxtDetailTime" Text="공부 시작: 2026-05-30" FontSize="11" Foreground="#64748B" Margin="0,2,0,8"/>
                        
                        <!-- 집중 성과 배지 -->
                        <WrapPanel Orientation="Horizontal">
                            <Border Background="#EFF6FF" CornerRadius="6" Padding="8,4" Margin="0,0,8,4">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⏱️ 목표: " FontSize="11" FontWeight="Bold" Foreground="#1E40AF"/>
                                    <TextBlock Name="TxtDetailPlanned" Text="0분" FontSize="11" FontWeight="Bold" Foreground="#1D4ED8"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#ECFDF5" CornerRadius="6" Padding="8,4" Margin="0,0,8,4">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🎯 집중: " FontSize="11" FontWeight="Bold" Foreground="#065F46"/>
                                    <TextBlock Name="TxtDetailFocused" Text="0분 0초" FontSize="11" FontWeight="Bold" Foreground="#047857"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#FEF2F2" CornerRadius="6" Padding="8,4" Margin="0,0,0,4">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⚠️ 딴짓: " FontSize="11" FontWeight="Bold" Foreground="#991B1B"/>
                                    <TextBlock Name="TxtDetailDistracted" Text="0초" FontSize="11" FontWeight="Bold" Foreground="#B91C1C"/>
                                </StackPanel>
                            </Border>
                        </WrapPanel>
                    </StackPanel>

                    <!-- 메모 본문 에디터 영역 (Read-only) -->
                    <Grid Grid.Row="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="작성된 메모 내용" FontSize="12" FontWeight="Bold" Foreground="#64748B" Margin="0,0,0,6"/>
                        <Border Grid.Row="1" Background="#F8FAFC" CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1">
                            <TextBox Name="TxtDetailMemo" BorderThickness="0" Background="Transparent" Padding="10"
                                     IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto" FontSize="13" Foreground="#334155" FontFamily="Consolas, Malgun Gothic"/>
                        </Border>
                        
                        <!-- 선택하지 않았을 때의 안내 메시지 -->
                        <Grid Grid.Row="1" Name="PanelPlaceholder" Background="White">
                            <TextBlock Text="왼쪽 세션 목록에서 세션을 선택해 주세요." Foreground="#94A3B8" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- 하단 조작 영역 -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Name="BtnCopyMemo" Content="전체 복사" Height="40" Width="100" Background="#EFF6FF" Foreground="#3B82F6" FontWeight="Bold" FontSize="13" Margin="0,0,10,0" Click="BtnCopyMemo_Click" Cursor="Hand" Visibility="Collapsed">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button Content="닫기" Height="40" Width="100" Background="#1E293B" Foreground="White" FontWeight="Bold" FontSize="13" Click="Close_Click" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Grid>
</Window>
