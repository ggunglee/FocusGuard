<Window x:Class="FocusGuard.DictTranslatorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="사전 및 번역" Height="450" Width="550"
        WindowStartupLocation="CenterOwner" WindowStyle="ToolWindow" Background="{DynamicResource WindowBackgroundBrush}"
        Topmost="True"
        UseLayoutRounding="True" SnapsToDevicePixels="True" TextOptions.TextFormattingMode="Display"
        Loaded="Window_Loaded">
    <Grid Margin="15">
        <TabControl Name="MainTabControl" Background="Transparent" BorderThickness="0" SelectionChanged="MainTabControl_SelectionChanged">
            <!-- 사전 탭 -->
            <TabItem Header="📖 단어 사전">
                <Grid Margin="0,15,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Text="단어 검색 (영한/국어 통합 - 로컬 자동 저장)" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                    <Grid Grid.Row="1" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Name="TxtDictInput" Grid.Column="0" Height="34" FontSize="14" Padding="8,4" VerticalContentAlignment="Center" BorderBrush="{DynamicResource InputBorderBrush}" Foreground="{DynamicResource InputForegroundBrush}" Background="{DynamicResource InputBackgroundBrush}" KeyDown="TxtDictInput_KeyDown"/>
                        <Button Name="BtnSearchDict" Grid.Column="1" Content="검색" Width="70" Margin="8,0,0,0" Background="{DynamicResource PrimaryButtonBrush}" Foreground="{DynamicResource PrimaryButtonTextBrush}" FontWeight="Bold" Click="BtnSearchDict_Click">
                            <Button.Template><ControlTemplate TargetType="Button"><Border Background="{TemplateBinding Background}" CornerRadius="6"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border></ControlTemplate></Button.Template>
                        </Button>
                    </Grid>
                    
                    <Border Grid.Row="2" Background="{DynamicResource CardBackgroundBrush}" CornerRadius="8" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                        <TextBox Name="TxtDictResult" BorderThickness="0" Background="Transparent" Padding="10" IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" FontSize="13" Foreground="{DynamicResource InputForegroundBrush}" FontFamily="Malgun Gothic"/>
                    </Border>
                </Grid>
            </TabItem>
            
            <!-- 번역 탭 -->
            <TabItem Header="🌐 문장 번역">
                <Grid Margin="0,15,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Text="번역할 문장" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                    <Border Grid.Row="1" Background="{DynamicResource CardBackgroundBrush}" CornerRadius="8" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" Margin="0,0,0,10">
                        <TextBox Name="TxtTransInput" BorderThickness="0" Background="Transparent" Padding="10" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" FontSize="13" Foreground="{DynamicResource InputForegroundBrush}" FontFamily="Malgun Gothic" KeyDown="TxtTransInput_KeyDown"/>
                    </Border>
                    
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Name="BtnTranslate" Content="번역 실행 (로컬 저장)" Height="30" Width="180" Background="{DynamicResource AccentBrush}" Foreground="{DynamicResource PrimaryButtonTextBrush}" FontWeight="Bold" Click="BtnTranslate_Click">
                            <Button.Template><ControlTemplate TargetType="Button"><Border Background="{TemplateBinding Background}" CornerRadius="6"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border></ControlTemplate></Button.Template>
                        </Button>
                    </StackPanel>

                    <Border Grid.Row="3" Background="{DynamicResource CardBackgroundBrush}" CornerRadius="8" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                        <TextBox Name="TxtTransResult" BorderThickness="0" Background="Transparent" Padding="10" IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" FontSize="13" Foreground="{DynamicResource InputForegroundBrush}" FontFamily="Malgun Gothic"/>
                    </Border>
                </Grid>
            </TabItem>
            
            <!-- 기록 관리 탭 -->
            <TabItem Header="📋 내 단어장 (기록)">
                <Grid Margin="0,15,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="저장된 사전 및 번역 기록" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                        <Button Name="BtnRefreshLogs" Grid.Column="1" Content="새로고침" Width="80" Height="26" Background="{DynamicResource SecondaryButtonBrush}" Foreground="{DynamicResource SecondaryButtonTextBrush}" FontWeight="Bold" Click="BtnRefreshLogs_Click">
                            <Button.Template><ControlTemplate TargetType="Button"><Border Background="{TemplateBinding Background}" CornerRadius="6"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border></ControlTemplate></Button.Template>
                        </Button>
                    </Grid>
                    
                    <Border Grid.Row="1" Background="{DynamicResource CardBackgroundBrush}" CornerRadius="8" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                        <ListView Name="ListLogs" BorderThickness="0" Background="Transparent" Foreground="{DynamicResource TextPrimaryBrush}" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Margin" Value="0,0,0,4"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="4,4,4,8">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal">
                                            <Border Background="{DynamicResource SecondaryButtonBrush}" CornerRadius="4" Padding="4,2" Margin="0,0,6,0">
                                                <TextBlock Text="{Binding type}" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}"/>
                                            </Border>
                                            <TextBlock Text="{Binding time}" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        
                                        <Button Grid.Row="0" Grid.Column="1" Grid.RowSpan="2" Content="❌ 삭제" Background="Transparent" BorderThickness="0" Foreground="{DynamicResource DangerLabelBrush}" FontSize="12" Cursor="Hand" Click="BtnDeleteLog_Click" Tag="{Binding rowIndex}">
                                            <Button.Template><ControlTemplate TargetType="Button"><Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="6,4"><ContentPresenter/></Border></ControlTemplate></Button.Template>
                                        </Button>
                                        
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding input}" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,4,0,2" TextWrapping="Wrap"/>
                                        <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Text="{Binding output}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>

